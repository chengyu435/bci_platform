    "# -*- coding: utf-8 -*-\n",
    "\n",
    "import os\n",
    "import sys\n",
    "import numpy as np\n",
    "\n",
    "# 添加父目录到 sys.path，使得能导入 bci_platform 包\n",
    "if \"__file__\" in globals():\n",
    "    sys.path.insert(0, os.path.dirname(os.path.dirname(os.path.abspath(__file__))))\n",
    "else:\n",
    "    sys.path.insert(0, os.path.dirname(os.getcwd()))\n",
    "\n",
    "from bci_platform.io.edf_bdf_reader import EDFBDFReader\n",
    "\n",
    "\n",
    "file_path = os.path.join(\"data\", \"S001R01.edf\")\n",
    "\n",
    "if not os.path.exists(file_path):\n",
    "    raise FileNotFoundError(\n",
    "        f\"未找到测试文件：{file_path}\\n\"\n",
    "        f\"请确认 S001R01.edf 已放入 data 文件夹。\"\n",
    "    )\n",
    "\n",
    "print(\"开始读取 EDF 文件:\")\n",
    "print(file_path)\n",
    "\n",
    "reader = EDFBDFReader(file_path)\n",
    "\n",
    "eeg = reader.read(preload=True, physical=True)\n",
    "\n",
    "reader.print_summary()\n",
    "\n",
    "print(\"\\n========== EDF 读取完成 ==========\")\n",
    "print(\"数据矩阵 shape:\", eeg.data.shape)\n",
    "print(\"通道数量:\", len(eeg.channel_names))\n",
    "print(\"采样率:\", eeg.main_sampling_rate)"
   ]
  },
